# TopSignal environment profiles
#
# This file is a reference template.
# - Copy backend variables to: backend/.env
# - Copy frontend variables to: frontend/.env.local
# - Cloud mode does NOT require Docker.

################################################################################
# Profile A: Cloud mode (no Docker required)
################################################################################

# Backend (.env)
DATABASE_URL=postgresql+psycopg://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
AUTH_REQUIRED=true

PROJECTX_API_BASE_URL=https://api.topstepx.com
# Use your TopstepX username plus the API key generated in TopstepX Settings -> API.
# ProjectX API Access must be subscribed and linked before loginKey authentication succeeds.
PROJECTX_USERNAME=your_topstepx_username
PROJECTX_API_KEY=your_topstepx_api_key
PROJECTX_INITIAL_LOOKBACK_DAYS=365
PROJECTX_SYNC_CHUNK_DAYS=90
PROJECTX_DAY_SYNC_LIMIT=1000
PROJECTX_YESTERDAY_REFRESH_MINUTES=180
TOPSIGNAL_DB_SCHEMA_INIT=full

# Frontend (.env.local)
VITE_API_BASE_URL=http://localhost:8000
# Cloud profile must use your hosted Supabase URL, not localhost.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

################################################################################
# Profile B: Local mode (Docker required via Supabase CLI)
################################################################################

# 1) Install Supabase CLI
# 2) Start local stack: supabase start

# Backend (.env)
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
# Use local JWT secret from `supabase status` when validating local tokens.
SUPABASE_JWT_SECRET=your_local_supabase_jwt_secret
# Optional explicit local endpoints:
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
AUTH_REQUIRED=true

PROJECTX_API_BASE_URL=https://api.topstepx.com
# Use your TopstepX username plus the API key generated in TopstepX Settings -> API.
# ProjectX API Access must be subscribed and linked before loginKey authentication succeeds.
PROJECTX_USERNAME=your_topstepx_username
PROJECTX_API_KEY=your_topstepx_api_key
PROJECTX_INITIAL_LOOKBACK_DAYS=365
PROJECTX_SYNC_CHUNK_DAYS=90
PROJECTX_DAY_SYNC_LIMIT=1000
PROJECTX_YESTERDAY_REFRESH_MINUTES=180
TOPSIGNAL_DB_SCHEMA_INIT=full

# Frontend (.env.local)
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_local_supabase_anon_key
